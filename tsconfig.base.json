{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["gremorie"],
    "paths": {
      "@gremorie/ng-core": ["./packages/ng-core/src/index.ts"],
      "@gremorie/ng-attachments": ["./packages/ng-attachments/src/index.ts"],
      "@gremorie/ng-prompt-input": ["./packages/ng-prompt-input/src/index.ts"],
      "@gremorie/ng-scroll-area": ["./packages/ng-scroll-area/src/index.ts"],
      "@gremorie/ng-charts": ["./packages/ng-charts/src/index.ts"]
    }
  }
}
