{
  "name": "rx-data",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/rx-data/src",
  "projectType": "library",
  "tags": ["scope:lib", "type:component", "category:data", "framework:react"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/rx-data",
        "command": "tsc -p tsconfig.lib.json"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/rx-data",
        "command": "vitest run"
      }
    }
  }
}
