{
  "name": "@gremorie/rx-artifacts",
  "version": "0.4.0",
  "description": "Generative-UI artifacts (Artifact, CodeBlock, WebPreview) for the React edition of Gremorie. Optional add-on — not bundled in @gremorie/react.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usegremorie/gremorie.git",
    "directory": "packages/rx-artifacts"
  },
  "keywords": [
    "react",
    "ai",
    "artifact",
    "code-block",
    "generative-ui",
    "gremorie"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
