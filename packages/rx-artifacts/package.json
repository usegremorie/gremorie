    "@gremorie/rx-overlays": ">=0.3.0",
    "react": "^19.2.7"
  },
  "dependencies": {
    "lucide-react": "^0.547.0",
    "shiki": "^4.3.0",
    "tslib": "^2.3.0"
  },
  "sideEffects": false,
  "homepage": "https://gremorie.com",
  "publishConfig": {
