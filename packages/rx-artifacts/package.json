      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@gremorie/rx-core": ">=0.3.0",
    "@gremorie/rx-data": ">=0.3.0",
    "@gremorie/rx-display": ">=0.3.0",
