{
  "name": "rx-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/rx-core/src",
  "projectType": "library",
  "tags": ["scope:lib", "type:core", "framework:react"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/rx-core",
        "parallel": false,
        "commands": [
          "tsc -p tsconfig.lib.json",
          "tailwindcss -i styles/globals.src.css -o dist/styles/globals.css --minify"
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/rx-core",
        "command": "vitest run"
      }
    }
  }
}
