{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "emitDeclarationOnly": false,
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "isolatedModules": false,
    "noEmitOnError": false,
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
