{
  "name": "registry",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/registry/src",
  "projectType": "library",
  "tags": ["scope:registry", "type:tool"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist", "{projectRoot}/bin"],
      "options": {
        "cwd": "packages/registry",
        "command": "tsc -p tsconfig.lib.json"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/docs/public/r"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node packages/registry/bin/registry.js generate"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
