  "description": "Gremorie registry generator. Reads packages/ng-* source + co-located usage.md and emits the JSON registry consumed by the CLI and the MCP server.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usegremorie/gremorie.git",
    "directory": "packages/registry"
  },
  "keywords": [
    "gremorie",
    "registry",
    "shadcn",
    "design-system",
    "ai"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
