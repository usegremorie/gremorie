{
  "name": "rx-ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/rx-ai/src",
  "projectType": "library",
  "tags": ["scope:lib", "type:component", "category:ai", "framework:react"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/rx-ai",
        "command": "tsc -p tsconfig.lib.json"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "storybook dev -p 4401 --no-open -c packages/rx-ai/.storybook"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/storybook/rx-ai"],
      "options": {
        "command": "storybook build -c packages/rx-ai/.storybook -o dist/storybook/rx-ai --stats-json"
      }
    }
  }
}
