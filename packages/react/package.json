{
  "name": "@gremorie/react",
  "version": "0.5.1",
  "description": "The complete React edition of Gremorie — every component category in one package. The per-category packages remain available for granular installs and the registry.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usegremorie/gremorie.git",
    "directory": "packages/react"
  },
  "keywords": [
    "react",
    "design-system",
    "ui",
    "ai",
    "components",
    "gremorie"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "dependencies": {
    "@gremorie/rx-core": ">=0.5.1",
    "@gremorie/rx-forms": ">=0.5.1",
    "@gremorie/rx-display": ">=0.5.1",
    "@gremorie/rx-overlays": ">=0.5.1",
    "@gremorie/rx-feedback": ">=0.5.1",
    "@gremorie/rx-navigation": ">=0.5.1",
    "@gremorie/rx-containers": ">=0.5.1",
    "@gremorie/rx-data": ">=0.5.1",
    "@gremorie/rx-ai": ">=0.5.1",
    "tslib": "^2.3.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "homepage": "https://gremorie.com",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/usegremorie/gremorie/issues"
  },
  "author": "Gremorie (https://github.com/usegremorie)"
}
