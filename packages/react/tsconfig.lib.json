{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmitOnError": false,
    "composite": true,
    "isolatedModules": true,
    "types": []
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ],
  "references": [
    { "path": "../rx-core/tsconfig.lib.json" },
    { "path": "../rx-forms/tsconfig.lib.json" },
    { "path": "../rx-display/tsconfig.lib.json" },
    { "path": "../rx-overlays/tsconfig.lib.json" },
    { "path": "../rx-feedback/tsconfig.lib.json" },
    { "path": "../rx-navigation/tsconfig.lib.json" },
    { "path": "../rx-containers/tsconfig.lib.json" },
    { "path": "../rx-data/tsconfig.lib.json" },
    { "path": "../rx-ai/tsconfig.lib.json" }
  ]
}
