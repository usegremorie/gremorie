# Normalize line endings to LF in the repository and on checkout, so Windows
# and Linux (local and CI) agree and Prettier does not flag CRLF files.
* text=auto eol=lf

# Binary assets must never be touched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.mp4 binary
*.zip binary
