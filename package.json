{
  "name": "shadng",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Angular AI-native component library — shadcn for Angular, focused on AI.",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalvner/shadng.git"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "build:core": "nx build shadng-core",
    "build:lib": "nx build shadng-prompt-input",
    "build:docs": "nx build docs",
    "build:playground": "nx build playground",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "serve:playground": "nx serve playground",
    "serve:docs": "nx serve docs",
    "storybook": "nx storybook shadng-prompt-input",
    "build-storybook": "nx build-storybook shadng-prompt-input",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "nx run-many -t build --projects=shadng-core,shadng-prompt-input && changeset publish",
    "release": "npm run changeset:publish"
  },
  "private": true,
  "devDependencies": {
    "@analogjs/platform": "^2.5.1",
    "@analogjs/vite-plugin-angular": "^2.5.1",
    "@analogjs/vitest-angular": "^2.5.1",
