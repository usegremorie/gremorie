{
  "name": "gremorie",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Gremorie: AI-native design system. Distributed via registry + MCP for AI-driven generation. Angular edition first; React coming.",
  "repository": {
    "type": "git",
    "url": "https://github.com/usegremorie/gremorie.git"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
    "build": "nx run-many -t build",
    "build:core": "nx build ng-core",
    "build:ai": "nx build ng-ai",
    "build:containers": "nx build ng-containers",
    "build:data": "nx build ng-data",
    "build:rx-core": "nx build rx-core",
    "build:rx-ai": "nx build rx-ai",
    "build:docs": "nx build docs",
    "build:docs-ng": "nx build docs-ng",
    "build:playground": "nx build playground",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "serve:playground": "nx serve playground",
    "serve:docs": "nx serve docs",
    "serve:docs-ng": "nx serve docs-ng",
    "serve:tokens": "nx serve tokens-atlas",
    "storybook": "nx storybook ng-ai",
    "storybook:rx": "nx storybook rx-ai",
    "build-storybook": "nx build-storybook ng-ai",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "build:libs": "nx run-many -t build --projects=cli,ng-core,ng-ai,ng-containers,ng-data,ng-display,ng-feedback,angular,rx-core,rx-ai,rx-artifacts,rx-containers,rx-data,rx-display,rx-feedback,rx-forms,rx-navigation,rx-overlays,react",
    "release:dry": "npm run build:libs && node scripts/release.mjs --dry-run",
    "release": "npm run build:libs && node scripts/release.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --flag v10_config_lookup_from_file --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,html,yml,yaml}": "prettier --write"
  },
  "private": true,
  "devDependencies": {
    "@analogjs/content": "^2.5.3",
    "@analogjs/platform": "^2.5.3",
    "@analogjs/router": "^2.5.3",
    "@analogjs/vite-plugin-angular": "^2.5.3",
    "@analogjs/vitest-angular": "^2.5.3",
    "@angular-devkit/build-angular": "^21.2.13",
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "^22.7.2",
    "@nx/devkit": "22.7.2",
    "@nx/eslint": "^22.7.2",
    "@nx/eslint-plugin": "^22.7.2",
    "@nx/js": "22.7.2",
    "@nx/playwright": "^22.7.2",
    "@nx/storybook": "^22.7.2",
    "@nx/vite": "^22.7.2",
    "@nx/web": "22.7.2",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~21.2.0",
    "@spartan-ng/cli": "^0.0.1-alpha.694",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/angular": "^9.1.20",
    "@storybook/react-vite": "^9.1.20",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/d3-format": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "husky": "^9.1.7",
    "jsdom": "^22.0.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^17.0.7",
    "ng-packagr": "~21.2.5",
    "nx": "22.7.2",
    "prettier": "^3.8.1",
    "storybook": "^9.1.20",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "^6.3.2",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "4.0.18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "webpack": "5.106.2"
  },
  "dependencies": {
    "@angular/cdk": "^21.2.13",
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/platform-server": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/lucide": "^33.2.2",
    "@spartan-ng/brain": "^0.0.1-alpha.694",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/dompurify": "^3.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "d3-format": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "date-fns": "^4.3.0",
    "dompurify": "^3.4.5",
    "embla-carousel-react": "^8.6.0",
    "front-matter": "^4.0.2",
    "input-otp": "^1.4.2",
    "kleur": "^4.1.5",
    "marked": "^15.0.7",
    "marked-gfm-heading-id": "^4.1.1",
    "marked-highlight": "^2.2.1",
    "marked-mangle": "^1.1.10",
    "mermaid": "^10.2.4",
    "ngx-scrollbar": "^19.1.5",
    "postcss": "^8.5.3",
    "prismjs": "^1.29.0",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.76.1",
    "rxjs": "~7.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.4",
    "vaul": "^1.1.2"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
