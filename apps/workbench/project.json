{
  "name": "workbench",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/workbench/src",
  "projectType": "application",
  "tags": ["scope:app", "type:app"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "apps/workbench",
        "command": "vite --port 5025"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/workbench",
        "command": "vite build"
      }
    }
  }
}
